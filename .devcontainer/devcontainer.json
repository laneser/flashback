{
  "name": "Flashback Android",
  "build": {
    "dockerfile": "Dockerfile"
  },
  "runArgs": [
    "--add-host=host.docker.internal:host-gateway"
  ],
  "customizations": {
    "vscode": {
      "extensions": [
        "fwcd.kotlin",
        "vscjava.vscode-gradle"
      ]
    }
  },
  "postCreateCommand": "cd /workspaces/flashback && gradle wrapper --gradle-version 8.11.1",
  "remoteEnv": {
    "ANDROID_HOME": "/opt/android-sdk",
    "ADB_SERVER_SOCKET": "tcp:host.docker.internal:5037"
  }
}
